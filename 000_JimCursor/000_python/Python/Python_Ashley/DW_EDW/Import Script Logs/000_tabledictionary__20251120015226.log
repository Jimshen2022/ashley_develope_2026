SELECT TOP 10 *
FROM 
	Manufacturing_Inventory_MIL.IMHIST   AS T1, 
	MasterData_ItemMaster_MIL.ITMRVA AS T2

WHERE T1.ITNBR = T2.ITNBR AND T1.HOUSE = T2.STID
	AND T1.TCODE IN ('RP','RI','RM','RS') AND T1.UPDDT BETWEEN 
    '1' + FORMAT(DATEADD(DAY, -30, GETDATE()), 'yyMMdd') 
    AND 
    '1' + FORMAT(DATEADD(DAY, 1, GETDATE()), 'yyMMdd')
	AND T1.ITNBR = 'WNK102493' 
	AND T1.TRQTY <>0  
ORDER BY T1.UPDDT DESC  


SELECT TOP 10 *
FROM PQS_DataFactory_MIL.PCF216FS AS t1


GO
SELECT t1.wh_id
	, t1.serial_number
	, t1.item_number
	, t1.po_number
	, t1.location_id
	, CASE
			WHEN t1.location_id = 'NG001VD3' THEN 'Send back to Vendor for fixing'
			WHEN t1.location_id = 'NG001CG3' THEN 'Whse CaseGoods Damaged'
			WHEN t1.location_id = 'NG001UP3' THEN 'Whse UPH Damaged'
			WHEN t1.location_id = 'NG001CK3' THEN 'Checking Pieces'
			WHEN t1.location_id = 'NG001MT1' THEN 'Checking Mattresses'
			WHEN t1.location_id = 'DR001AA1' THEN 'Shipping Supervisor Unpicked'
			WHEN t1.location_id = 'DR001AA2' THEN 'Vendor Short Shipment'
			WHEN t1.location_id = 'DR001AA3' THEN 'Vendor Over Shipment'
			WHEN t1.location_id = 'DR001AB1' THEN 'Shipping Supervisor Unpicked'
			ELSE 'Check' END AS Location_Meaning
	, t1.received_date
	, t1.ship_date
FROM Distribution_Warehouse_Wholesale.t_serial_active  AS T1
WHERE  t1.wh_id  IN ('335') AND SUBSTRING(T1.location_id,1,2) IN ('DR','NG') 
AND t1.serial_no_status NOT IN ('O') and t1.master_status NOT IN ('S') 

GO
--t_serial_active
-- t_serial_active table? serial_no_status <>ï¿½O'   and  master_status <> 'S'  ?? sn in warehouse + load ? sn?

-- racking onhand
SELECT t1.item_number, t1.location_id, COUNT(t1.serial_number) as OnHand
FROM Distribution_Warehouse_Wholesale.t_serial_active  AS T1
WHERE  t1.wh_id  IN ('335') AND T1.location_id LIKE 'A3%' AND t1.serial_no_status NOT IN ('O') and t1.master_status NOT IN ('S') 
GROUP BY t1.item_number, t1.location_id

-- receiving stage onhand
SELECT t1.item_number, 'RS*' AS Receiving_Stage, COUNT(t1.serial_number) as OnHand
FROM Distribution_Warehouse_Wholesale.t_serial_active  AS T1
WHERE  t1.wh_id  IN ('335') AND T1.location_id LIKE 'RS%' AND t1.serial_no_status NOT IN ('O') and t1.master_status NOT IN ('S') 
GROUP BY t1.item_number




