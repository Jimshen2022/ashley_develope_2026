SELECT DATEPART(YYYY,j1.Trx_Date)*100 +FORMAT(DATEPART(ISO_WEEK, j1.Trx_Date), '00') AS YEARWEEK, 
	SUM(j1.UPH) AS UPH
	, SUM(J1.RP) AS RP
	, SUM(J1.CG) AS CG

FROM 
(
SELECT T3.Trx_Date
	, SUM(CASE
			WHEN T3.Product = 'UPH' THEN T3.Shipped_Qty ELSE 0 END) AS 'UPH'
    , SUM(CASE
			WHEN T3.Product = 'RP' THEN T3.Shipped_Qty ELSE 0 END) AS 'RP'
	, SUM(CASE
			WHEN T3.Product = 'CG' THEN T3.Shipped_Qty ELSE 0 END) AS 'CG'
FROM 
(
SELECT CAST(t1.[start_tran_date] AS DATE) AS Trx_Date
	, t1.tran_type
	, t1.description
	, t2.ITCLS
	, (CASE 
		WHEN SUBSTRING(t1.item_number,1,4) = '100-' THEN 'CG'
		WHEN t1.item_number LIKE  'RP%' THEN 'RP'
		WHEN SUBSTRING(t1.item_number,1,1) IN ('1','2','3','4','5','6','7','8','9','U') THEN 'UPH'
		ELSE 'CG' END) AS Product
--	, SUM(CASE 
--		WHEN t1.tran_type IN ('151','183') THEN t1.tran_qty 
--		ELSE - t1.tran_qty END) AS Received_Qty
	, SUM(CASE 
		WHEN t1.tran_type IN ('347') THEN t1.tran_qty 
		ELSE 0 END) AS Shipped_Qty

FROM Distribution_Warehouse_Wholesale.TranLog AS t1
LEFT JOIN (SELECT a.ITNBR, a.ITCLS FROM MasterData_ItemMaster_AFI.ITMRVA AS a WHERE a.STID = '335') AS t2 ON t1.item_number = t2.ITNBR
WHERE t1.wh_id IN ('335') AND t1.start_tran_date > '2024-01-01' 
	AND t1.tran_type IN ('347')
GROUP BY CAST(t1.[start_tran_date] AS DATE)
		, t1.tran_type
		, t1.description
		, t2.ITCLS
	, (CASE 
		WHEN SUBSTRING(t1.item_number,1,4) = '100-' THEN 'CG'
		WHEN t1.item_number LIKE  'RP%' THEN 'RP'
		WHEN SUBSTRING(t1.item_number,1,1) IN ('1','2','3','4','5','6','7','8','9','U') THEN 'UPH'
		ELSE 'CG' END)
) AS T3
GROUP BY T3.Trx_Date
) as j1

GROUP BY DATEPART(YYYY,j1.Trx_Date)*100 +FORMAT(DATEPART(ISO_WEEK, j1.Trx_Date), '00') 
ORDER BY DATEPART(YYYY,j1.Trx_Date)*100 +FORMAT(DATEPART(ISO_WEEK, j1.Trx_Date), '00') 
