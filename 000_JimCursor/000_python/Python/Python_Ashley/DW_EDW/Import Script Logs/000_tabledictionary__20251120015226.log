SELECT [home_wh_id]
             , CAST([work_day] AS DATE) [work_day]
             --, [work_shift_id]
             , [source]
             , b.[emp_number]
             , b.[work_shift]
             , [actual_clock_in]
             , [actual_clock_out]
             , [clock_in]
             , [clock_out]
             , a.[home_department] AS [dept]
             , b.[name]
             , b.[supervisor_nbr]
             , b.[supervisor]
             , b.[status]
             , c.[description]
			 , cast(b.[return_date] AS DATE) [return_date]
             , CASE
                   WHEN a.clock_out <> '' THEN
                       a.clock_out
