	  --,CASE WHEN b.AFIFinanceDivision LIKE '%Upholstery%' THEN a.[Quantity Shipped] ELSE 0 END [UPH]
	  ,CASE WHEN c.pick_put_id LIKE '%UPH%' THEN 'UPH' WHEN c.pick_put_id NOT LIKE '%UPH%' THEN 'CG' ELSE NULL END AS [Item_Type]
  FROM [Distribution_Warehouse_Wholesale].[ExceptionLog] a
