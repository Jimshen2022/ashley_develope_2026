SELECT  t.location_id, t.status, t.capacity_volume, t.pick_area, t.location_tier, SUBSTRING(t.location_id,4,2) AS Aisle, t1.CapacityVolume, 
	CONVERT(DECIMAL(10,2),t.length*0.0254) AS 'Loc_length(m)',
	CONVERT(DECIMAL(10,2),t.width *0.0254) AS 'Loc_width(m)',
	CONVERT(DECIMAL(10,2),t.height *0.0254) as 'Loc_height(m)',
	CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)) AS 'Loc_CBM',
(CASE 
    WHEN SUBSTRING(t.location_id,4,2) IN ('15') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'CG_rails_area'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'CG_3.5X7_area'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M','P','R','T','V','X') THEN 'CG_3.5X5_area'
    WHEN SUBSTRING(t.location_id,4,2) IN ('18') THEN 'CG_bulk_stack_area'
	WHEN t.pick_area LIKE 'UPH%' THEN 'UPH_racking_area'
	ELSE 'CG_racking_area' END) AS Dim_Category,
(CASE 
	WHEN SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'A' 
	WHEN SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M','P','R','T','V','X') THEN 'B' 
	ELSE 'Check' END
	) AS Location_side,
(CASE 
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN 'NO_SKID'
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') THEN '5X8'
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,2) IN ('FN','FP','FQ','FR','FS','FT','FU','FV','FW','FX','FY','FZ',
	'HA','HB','HC','HD','HE','HF','HG','HH','HJ','HK','HL','HM','HN','HP','HQ','HR','HS','HT','HU','HV','HW','HX','HY','HZ','KA','KB','KC','KD') THEN 'NO_SKID'
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') THEN '5X7'
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') THEN '5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') THEN '5X7'
	WHEN SUBSTRING(t.location_id,4,2) IN ('14') THEN '5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') THEN '5X7'
	WHEN SUBSTRING(t.location_id,4,2) IN ('16') THEN '5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M','P','R') THEN '3.5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q') THEN '3.5X7'
	ELSE 'NO_SKID' END		
	) AS Pallet_Type,
(CASE
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN 0
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,2) IN ('FN','FP','FQ','FR','FS','FT','FU','FV','FW','FX','FY','FZ',
	'HA','HB','HC','HD','HE','HF','HG','HH','HJ','HK','HL','HM','HN','HP','HQ','HR','HS','HT','HU','HV','HW','HX','HY','HZ','KA','KB','KC','KD') THEN 0
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 3
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 4
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3
	WHEN SUBSTRING(t.location_id,4,2) IN ('14') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('16') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') THEN 1
	ELSE 0 END) AS Capacity_by_pallet,
(CASE	
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN CONVERT(INT, t.capacity_volume*0.7/0.93)
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 3*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 4*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('14') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 1*15
	WHEN SUBSTRING(t.location_id,4,2) IN ('16') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('18') THEN CONVERT(INT, t.capacity_volume*0.7/0.93)
	WHEN t1.CapacityVolume = 350000 then 7
	WHEN t1.CapacityVolume = 400000 then 8
	WHEN t1.CapacityVolume = 450000 then 9
	WHEN t1.CapacityVolume = 500000 then 10
	WHEN t1.CapacityVolume = 600000 then 12	
	ELSE 0 END) AS Capacity_by_pieces
FROM 
(
SELECT * FROM Distribution_Warehouse_Wholesale.t_location AS t0
WHERE t0.wh_id IN ('335') AND t0.location_id like 'A3%' AND t0.TypeDescription IN ('I','P','M','A','X')
)  as t  
LEFT JOIN 
(SELECT c.LocationId, MIN(c.CapacityVolume) AS CapacityVolume 
FROM Distribution_Warehouse_Wholesale.t_class_loca c 
WHERE c.WhId IN ('335') AND c.CapacityVolume>0 and c.LocationId like 'A3%' 
GROUP BY c.LocationId 
) as t1 ON t.location_id = t1.LocationId
ORDER BY t.location_id
