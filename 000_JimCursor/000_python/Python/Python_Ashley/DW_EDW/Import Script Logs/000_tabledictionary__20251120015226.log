GO
select
       t1.[Date]
	  ,t1.[wh_id]
	  ,t1.[Hr]
      ,t1.[item_number]
	  ,t1.[staging_location]
      ,t1.[load_id]
	  ,t1.[pick_category] as planned_pick_category
	  ,t1.[SCOOPQTY]
      ,t1.planned_quantity
	  ,t2.item_counts_unloaded
	  --,t3.[actual_crossdocked_category]
      --,t3.item_counts_crossdocked
	  --,t4.crossdock_overridden_loadid
	  --,t4.[overidden_crossdocked_category]
      --,t4.crossdock_overridden_quantity
from
(SELECT 
	   a.[Date]
	  ,a.[wh_id]
	  ,a.[Hr]
      ,a.[item_number]
	  ,a.[staging_location]
      ,a.[load_id]
	  ,a.[pick_category]
	  ,a.[SCOOPQTY]
      ,sum(a.[planned_quantity]) as planned_quantity
FROM(
SELECT 
	   i.[SCOOPQTY]
	  ,p.[pick_id]
      ,p.[order_number]
      ,p.[line_number]
      ,p.[type]
      ,p.[uom]
      ,p.[work_q_id]
      ,p.[work_type]
      ,p.[label_number]
      ,p.[status]
      ,p.[item_number]
      ,p.[lot_number]
      ,p.[serial_number]
      ,p.[unplanned_quantity]
      ,p.[planned_quantity]
      ,p.[picked_quantity]
      ,p.[staged_quantity]
      ,p.[loaded_quantity]
      ,p.[pick_location]
      ,p.[picking_flow]
      ,p.[staging_location]
      ,p.[zone]
      ,p.[wave_id]
      ,p.[load_id]
      ,p.[load_sequence]
      ,p.[stop_id]
      ,p.[container_id]
      ,p.[pick_category]
      ,p.[user_assigned]
      ,p.[bulk_pick_flag]
      ,p.[stacking_sequence]
      ,p.[pick_area]
      ,p.[wh_id]
	   --CASE WHEN wh_id in ('1','ECR','28') THEN DATEADD(HH,-5, SYSDATETIME())
	   --WHEN (wh_id in ('1','ECR','28') THEN DATEADD(HH,-5, SYSDATETIME())
	   ,CASE WHEN p.wh_id IN ('5','42') THEN DW_Developer.fn_GetPSTDate(GETDATE())
	   WHEN p.wh_id IN ('1','ECR','28') THEN DW_Developer.fn_GetCSTDate(GETDATE())
	   ELSE DW_Developer.fn_GetESTDate(GETDATE()) END AS [TIME]

	   ,DATEPART(hour, CASE WHEN p.wh_id IN ('5','42') THEN DW_Developer.fn_GetPSTDate(GETDATE())
	   WHEN p.wh_id IN ('1','ECR','28') THEN DW_Developer.fn_GetCSTDate(GETDATE())
	   ELSE DW_Developer.fn_GetESTDate(GETDATE())END) AS Hr

	   ,CAST(CASE WHEN p.wh_id IN ('5','42') THEN DW_Developer.fn_GetPSTDate(GETDATE())
	   WHEN p.wh_id IN ('1','ECR','28') THEN DW_Developer.fn_GetCSTDate(GETDATE())
	   ELSE DW_Developer.fn_GetESTDate(GETDATE())END AS DATE) AS [Date]

	   --,SYSDATETIME() AS TIME2
  FROM [Distribution_Warehouse_Wholesale].[PickDetail] p
  LEFT JOIN [MasterData_ItemMaster_AFI].[ITBEXT] i
  ON p.wh_id=i.HOUSE
  AND p.[item_number]=i.[ITNBR]
  --Where [wh_id]='1'
  WHERE p.wh_id in ('1','15','17','5','28','42','ECR')
  AND p.status='RELEASED'
  ) a
       group by
       a.[Date]
	  ,a.[wh_id]
	  ,a.[Hr]
      ,a.[item_number]
	  ,a.[staging_location]
      ,a.[load_id]
	  ,a.[pick_category]
	  ,a.[SCOOPQTY]
	  ) as t1
 JOIN ( 
SELECT
f.[Date],
f.wh_id,
f.Hr,
f.item_number,
count(item_number) as item_counts_unloaded
--SUM(f.Casegoods) [Casegoods],
--SUM(f.UPH) [UPH],
--count (distinct f.control_number) as Container

FROM(
SELECT
 CAST(a.end_tran_date AS DATE) [Date]
,DATEPART(hour, [end_tran_time]) AS Hr
,a.item_number
,a.wh_id
,a.tran_qty
,b.pick_put_id
,a.[control_number]
,CASE WHEN b.pick_put_id LIKE '%UPH%' THEN a.tran_qty ELSE 0 END [UPH]
,CASE WHEN b.pick_put_id NOT LIKE '%UPH%' THEN a.tran_qty ELSE 0 END [Casegoods]

 


FROM(
SELECT  [tran_type]
      ,a.[description]
      ,[start_tran_date]
      ,[start_tran_time]
      ,[end_tran_date]
      ,[end_tran_time]
      ,[employee_id]
      ,[control_number]
      ,[line_number]
      ,[control_number_2]
      ,[outside_id]
      ,a.[wh_id]
      ,[location_id]
      ,[hu_id]
      ,[num_items]
      ,a.[item_number]
      ,[lot_number]
      ,a.[uom]
      ,[tran_qty]
      ,[wh_id_2]
      ,[location_id_2]
      ,[verify_status]
      ,[employee_id_2]
      ,[routing_code]
      ,[hu_id_2]
      ,[return_disposition]
      ,[elapsed_time]
      ,[log_id]
      ,[group_id]
      ,[afi_package_rate]
  FROM [Distribution_Warehouse_Wholesale].[TranLog] a
  --WHERE CAST(a.end_tran_date AS DATE) BETWEEN DATEADD(MONTH,-8,GETDATE()) AND GETDATE()
  --WHERE CAST(a.end_tran_date AS DATE)='20211025'
  WHERE CAST(a.end_tran_date AS DATE)= CAST(GETDATE() AS DATE)
  AND a.tran_type='151'
  AND a.description NOT LIKE '%Shuttle%' 
  AND wh_id in ('335')
  --AND wh_id in ('1')


  ) a

 

  LEFT JOIN 
  (SELECT DISTINCT 
  a.item_number,
  a.wh_id,
  a.pick_put_id,
  a.commodity_code

 

 FROM  Distribution_Warehouse_wholesale.t_item_master a
 WHERE a.commodity_code LIKE 'Z%'
 AND a.commodity_code NOT LIKE '%K'
 ) b
  ON a.item_number=b.item_number
  AND a.wh_id=b.wh_id) f

 

GROUP BY
f.[Date],
f.wh_id,
f.Hr,
f.item_number

--order by
--f.Hr,
--f.item_number
 ) as t2

  on        t1.[Date] = t2.[Date]
        AND t1.wh_id = t2.wh_id
        AND t1.Hr = t2.Hr
		AND t1.item_number = t2.item_number

		order by
	   t1.[wh_id]
	  ,t1.[Hr]

GO
  SELECT [Invoice date], SUM([Quantity Shipped]) AS "UNITS",
  SUM([Invoice Discount])+SUM([Amount Shipped])+ SUM([Invoiced Line Item Freight]) AS "TOTAL $"
  ,[Warehouse] as DC


  FROM [PowerBI_Wholesale].[InvoiceHistory]

  WHERE [Warehouse] in ('335')
  --AND [Invoice Date] BETWEEN '20210901' AND '20211025'
  AND CAST([Invoice Date] AS DATE) BETWEEN DATEADD(MONTH,-3,GETDATE()) AND GETDATE()
  GROUP BY [Invoice date],[Warehouse]
  ORDER BY [Invoice date] ASC

