/* HJPOD */
SELECT TOP 10 *
FROM Distribution_Warehouse_Wholesale.t_pod_log AS T1

SELECT TOP 10 *
FROM Distribution_Warehouse_Wholesale.t_asn AS T1


GO
/* Yard open qty */
WITH YARD_CET (item_number, yard_open_qty) AS 
(
SELECT y1.item_number, SUM(y1.quantity_shipped-y1.quantity_received) AS yard_open_qty
FROM 
(
SELECT t1.wh_id 
	, t1.asn_id
	, t1.asn_number
	, t1.vendor_id
	, t1.carrier_id
	, t1.expected_arrival
	, t1.shipped
	, t1.total_quantity
	, t1.total_weight
	, t1.total_volume
	, t1.equipment_id
	, t1.trailer_type_name
	, t1.status
	, t1.sent_103_flag
	, t1.sent_101_flag
	, t2.asn_detail_id
	, t2.customer_po_number
	, t2.item_number
	, t2.uom
	, t2.quantity_shipped
	, t2.serial_number_start
	, t2.serial_number_end
	, t2.quantity_received
	, t2.born_on_date
	, t2.sn_coo
	, t4.entered_yard
	, CONCAT(t1.equipment_id, '_', t2.customer_po_number) AS equipment_po
FROM (SELECT  * FROM Distribution_Warehouse_Wholesale.t_asn as a1 
WHERE a1.wh_id = '335' and a1.status in ('NEW','CHECKED IN')) AS t1
LEFT JOIN (SELECT * 
			FROM Distribution_Warehouse_Wholesale.ASN_Detail AS a2 where a2.wh_id = '335') as t2
	ON t1.asn_id = t2.asn_id and t1.wh_id = t2. wh_id 
LEFT JOIN (SELECT  * FROM Distribution_Warehouse_Wholesale.t_trailer_asn as a3 WHERE a3.Wh_id = '335') as t3
	ON t1.asn_id = t3.AsnId and t1.wh_id= t3.Wh_id 
LEFT JOIN (SELECT a4.trailer_id, a4.carrier_id, a4.equipment_id, a4.wh_id, a4.entered_yard  FROM Distribution_Warehouse_Wholesale.Trailer  AS a4 WHERE a4.Wh_id = '335' and a4.status in ('IN DOOR','IN YARD CHASSIS') Group by a4.trailer_id, a4.carrier_id, a4.equipment_id, a4.wh_id, a4.entered_yard ) as t4
	on t3.TrailerId = t4.trailer_id and t3.Wh_id = t4.wh_id and t3.EquipmentId = t4.equipment_id
WHERE t1.status in ('CHECKED IN') 
AND CONCAT(t1.equipment_id, '_', t2.customer_po_number) 
NOT IN 
(SELECT DISTINCT CONCAT(t1.control_number,'_',t1.control_number_2) AS equipment_po
FROM Distribution_Warehouse_Wholesale.TranLog AS t1
WHERE t1.tran_type IN ('151','183','951') AND t1.wh_id = '335' 
AND t1.start_tran_date BETWEEN DATEADD(DAY, -10, GETDATE()) AND GETDATE())
AND t2.quantity_shipped - t2.quantity_received >0
) AS y1
GROUP BY y1.item_number
),

-- ADD racking A3* inventory 
INV_CET (item_number, location_id, on_hand) AS 
(
SELECT t1.item_number, t1.location_id, COUNT(t1.serial_number) as OnHand
FROM Distribution_Warehouse_Wholesale.t_serial_active  AS T1
WHERE  t1.wh_id  IN ('335') AND T1.location_id LIKE 'A3%' AND t1.serial_no_status NOT IN ('O') and t1.master_status NOT IN ('S') 
GROUP BY t1.item_number, t1.location_id
),

-- ADD receiving stage RS* inventory 
Received_stage_CET (item_number, Receiving_Stage, received_on_stage_qty) AS
(
SELECT t1.item_number, t1.location_id, COUNT(t1.serial_number) as OnHand
FROM Distribution_Warehouse_Wholesale.t_serial_active  AS T1
WHERE  t1.wh_id  IN ('335') AND T1.location_id LIKE 'RS%' AND t1.serial_no_status NOT IN ('O') and t1.master_status NOT IN ('S') 
GROUP BY t1.item_number,t1.location_id
),

-- Firmed PO in next 3 Weeks
FirmPO  (item_number,Wk1,wk2,wk3) AS
(
SELECT a0.PTLITNBR, a0.PTLWEEK1,a0.PTLWEEK2,a0.PTLWEEK3
FROM Wholesale_DemandPlanning_AFI.PlanDetailTimeline AS a0  
WHERE a0.PTLDATATYPE = 'FIRM POS' AND a0.PTLWHSE = '335' AND (a0.PTLWEEK1 + a0.PTLWEEK2 + a0.PTLWEEK3) >0 
)





-- Items [onhand + (a0.PTLWEEK1 + a0.PTLWEEK2 + a0.PTLWEEK3) > 0 ]
SELECT T0.PTLITNBR, t1.PTLITNBR, 
		T2.ITCLS, T2.B2Z95S, 
		T3.PUTAWAY_CLASS,T3.SCOOPQTY, T3.SKIDSIZE AS PALLET_TYPE,
		T4.on_hand,
		t5.yard_open_qty,
        t1.PTLWEEK1, 
		t1.PTLWEEK2, 
		t1.PTLWEEK3,  
		t1.PTLWEEK1* T2.B2Z95S AS Wk1_Cubes, 
		t1.PTLWEEK2* T2.B2Z95S AS Wk2_Cubes,
		t1.PTLWEEK3* T2.B2Z95S AS Wk3_Cubes
FROM 
(
(
SELECT a0.PTLITNBR 
FROM Wholesale_DemandPlanning_AFI.PlanDetailTimeline AS a0  
WHERE a0.PTLDATATYPE = 'FIRM POS' AND a0.PTLWHSE = '335' AND (a0.PTLWEEK1 + a0.PTLWEEK2 + a0.PTLWEEK3) >0 
GROUP BY a0.PTLITNBR
UNION  
SELECT a1.item_number FROM Distribution_Warehouse_Wholesale.t_serial_active AS a1 
WHERE a1.wh_id IN ('335') AND a1.serial_no_status NOT IN ('O') and a1.master_status NOT IN ('S') 
GROUP BY a1.item_number 
)  
UNION
-- Yard
(SELECT a2.item_number FROM YARD_CET AS a2)
) AS T0 
LEFT JOIN (SELECT a.ITNBR, a.ITCLS, a.B2Z95S  FROM MasterData_ItemMaster_AFI.ITMRVA AS a WHERE a.STID IN ('335'))  AS T2 ON T1.PTLITNBR = T2.ITNBR
LEFT JOIN (SELECT b.ITNBR, b.TIHIUNLD, b.PICKPUT, b.ITMCLSID AS PUTAWAY_CLASS, b.UNITSWIDE, b.UNITLAYERS, b.UNITSDEEP, b.SCOOPQTY, b.SKIDSIZE  FROM MasterData_ItemMaster_AFI.ITBEXT as b WHERE b.House in ('335')) AS t3 ON t1.PTLITNBR = t3.itnbr 


SELECT i.ITNBR, i.ITCLS, i.B2Z95S, i1.TIHIUNLD, i1.PICKPUT, i1.PUTAWAY_CLASS, i1.UNITSWIDE, i1.UNITLAYERS, i1.UNITSDEEP, i1.SCOOPQTY, i1.SKIDSIZE 
FROM (SELECT * FROM MasterData_ItemMaster_AFI.ITMRVA AS a WHERE a.STID IN ('335'))  AS i, 
(SELECT b.ITNBR, b.TIHIUNLD, b.PICKPUT, b.ITMCLSID AS PUTAWAY_CLASS, b.UNITSWIDE, b.UNITLAYERS, b.UNITSDEEP, b.SCOOPQTY, b.SKIDSIZE  
FROM MasterData_ItemMaster_AFI.ITBEXT as b WHERE b.House in ('335')
) AS i1 
WHERE i.ITNBR = i1.ITNBR 




