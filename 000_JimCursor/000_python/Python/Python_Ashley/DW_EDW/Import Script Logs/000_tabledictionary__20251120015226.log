SELECT
f.[Date],
f.wh_id,
f.Hr,
f.item_number,
f.[actual_crossdocked_category],
sum(tran_qty) as item_counts_crossdocked,
f.[Item_Type]
--SUM(f.Casegoods) [Casegoods],
--SUM(f.UPH) [UPH],
--count (distinct f.control_number) as Container

FROM(
SELECT
 CAST(a.end_tran_date AS DATE) [Date]
,DATEPART(hour, [end_tran_time]) AS Hr
,a.item_number
,a.wh_id
,a.tran_qty
,b.pick_put_id
,a.[control_number]
,a.[actual_crossdocked_category]
,CASE WHEN b.pick_put_id LIKE '%UPH%' THEN a.tran_qty ELSE 0 END [UPH]
,CASE WHEN b.pick_put_id NOT LIKE '%UPH%' THEN a.tran_qty ELSE 0 END [Casegoods]
,CASE WHEN b.pick_put_id LIKE '%UPH%' THEN 'UPH' WHEN b.pick_put_id NOT LIKE '%UPH%' THEN 'CG' ELSE NULL END AS [Item_Type]


 


FROM(
SELECT  [tran_type]
      ,a.[description]
      ,[start_tran_date]
      ,[start_tran_time]
      ,[end_tran_date]
      ,[end_tran_time]
      ,[employee_id]
      ,[control_number]
      ,[line_number]
      ,[control_number_2]
      ,[outside_id]
      ,a.[wh_id]
      ,[location_id]
      ,[hu_id]
      ,[num_items]
      ,a.[item_number]
      ,[lot_number]
      ,a.[uom]
      ,[tran_qty]
      ,[wh_id_2]
      ,[location_id_2]
      ,[verify_status]
      ,[employee_id_2]
      ,[routing_code]
      ,[hu_id_2]
      ,[return_disposition]
      ,[elapsed_time]
      ,[log_id]
      ,[group_id]
      ,[afi_package_rate]
	  ,CASE WHEN a.[tran_type] LIKE '314' THEN 'TFER' ELSE 'PICK' END AS [actual_crossdocked_category]


  FROM [Distribution_Warehouse_Wholesale].[TranLog] a
  --WHERE CAST(a.end_tran_date AS DATE) BETWEEN DATEADD(MONTH,-8,GETDATE()) AND GETDATE()
  --WHERE CAST(a.end_tran_date AS DATE)='20211025'
  --WHERE CAST(a.end_tran_date AS DATE)= CAST(GETDATE() AS DATE)
  WHERE CAST(a.end_tran_date AS DATE) BETWEEN DATEADD(MONTH,-3,GETDATE()) AND GETDATE()
  AND a.tran_type in ('312','314')
  AND a.description NOT LIKE '%Shuttle%' 
  AND wh_id in ('1','15','17','5','28','42','ECR')
  --AND wh_id in ('1')


  ) a

 

  LEFT JOIN 
  (SELECT DISTINCT 
  a.item_number,
  a.wh_id,
  a.pick_put_id,
  a.commodity_code

 

 FROM  Distribution_Warehouse_wholesale.t_item_master a
 WHERE a.commodity_code LIKE 'Z%'
 AND a.commodity_code NOT LIKE '%K'
 ) b
  ON a.item_number=b.item_number
  AND a.wh_id=b.wh_id) f

 

GROUP BY
f.[Date],
f.wh_id,
f.Hr,
f.item_number,
f.[actual_crossdocked_category],
f.[Item_Type]

order by
f.[Date],
f.wh_id,
f.Hr,
f.item_number

