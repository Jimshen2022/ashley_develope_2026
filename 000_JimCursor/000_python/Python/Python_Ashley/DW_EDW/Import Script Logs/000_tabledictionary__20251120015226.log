/*Ashton locations capacity by pieces and pallets */

SELECT  t.location_id, t.TypeDescription, t.status, t.capacity_volume, t.pick_area, t.location_tier, SUBSTRING(t.location_id,4,2) AS Aisle, t1.CapacityVolume, 
	CONVERT(DECIMAL(10,2),t.length*0.0254) AS 'Loc_length(m)',
	CONVERT(DECIMAL(10,2),t.width *0.0254) AS 'Loc_width(m)',
	CONVERT(DECIMAL(10,2),t.height *0.0254) as 'Loc_height(m)',
	CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)) AS 'Loc_CBM',
(CASE 
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 'CG_bulk_stack_area'
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN 'CG_bulk_stack_area'
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,2) IN ('FN','FP','FQ','FR','FS','FT','FU','FV','FW','FX','FY','FZ',
	'HA','HB','HC','HD','HE','HF','HG','HH','HJ','HK','HL','HM','HN','HP','HQ','HR','HS','HT','HU','HV','HW','HX','HY','HZ','KA','KB','KC','KD') THEN 'CG_bulk_stack_area'
    WHEN SUBSTRING(t.location_id,4,2) IN ('15') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'CG_rails_area'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'CG_3.5X7_area'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M','P','R','T','V','X') THEN 'CG_3.5X5_area'
    WHEN SUBSTRING(t.location_id,4,2) IN ('18') THEN 'CG_bulk_stack_area'
	WHEN t.pick_area LIKE 'UPH%' THEN 'UPH_racking_area'
	ELSE 'CG_racking_area' END) AS location_Category,
(CASE 
	WHEN SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'A' 
	WHEN SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M','P','R','T','V','X') THEN 'B' 
	ELSE 'Check' END
	) AS Location_side,
(CASE
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 'NO_SKID'
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN 'NO_SKID'
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') THEN '5X8'
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,2) IN ('FN','FP','FQ','FR','FS','FT','FU','FV','FW','FX','FY','FZ',
	'HA','HB','HC','HD','HE','HF','HG','HH','HJ','HK','HL','HM','HN','HP','HQ','HR','HS','HT','HU','HV','HW','HX','HY','HZ','KA','KB','KC','KD') THEN 'NO_SKID'
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') THEN '5X7'
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') THEN '5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') THEN '5X7'
	WHEN SUBSTRING(t.location_id,4,2) IN ('14') THEN '5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') THEN '5X7'
	WHEN SUBSTRING(t.location_id,4,2) IN ('16') THEN '5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M','P','R') THEN '3.5X5'
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L','N','Q') THEN '3.5X7'
	ELSE 'NO_SKID' END		
	) AS Pallet_Type,
(CASE
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 0
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN 0
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,2) IN ('FN','FP','FQ','FR','FS','FT','FU','FV','FW','FX','FY','FZ',
	'HA','HB','HC','HD','HE','HF','HG','HH','HJ','HK','HL','HM','HN','HP','HQ','HR','HS','HT','HU','HV','HW','HX','HY','HZ','KA','KB','KC','KD') THEN 0
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 3
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 4
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3
	WHEN SUBSTRING(t.location_id,4,2) IN ('14') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('16') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') THEN 1
	ELSE 0 END) AS Capacity_by_pallet,
(CASE
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN CONVERT(INT, t.capacity_volume*0.000016*0.7/0.93)
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') AND SUBSTRING(t.location_id,8,1) IN ('1') AND SUBSTRING(t.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN CONVERT(INT, t.capacity_volume*0.000016*0.7/0.93)
	WHEN SUBSTRING(t.location_id,4,2) IN ('10') THEN 1
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('11') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 3*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('12') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 4*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 2*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('13') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 3*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('14') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') AND SUBSTRING(t.location_id,6,1) IN ('D','F','H','K','M') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('15') AND SUBSTRING(t.location_id,6,1) IN ('C','E','G','J','L') THEN 1*15
	WHEN SUBSTRING(t.location_id,4,2) IN ('16') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('17') THEN 1*10
	WHEN SUBSTRING(t.location_id,4,2) IN ('18') THEN CONVERT(INT, t.capacity_volume*0.000016*0.7/0.93)
	WHEN t1.CapacityVolume = 350000 then 7
	WHEN t1.CapacityVolume = 400000 then 8
	WHEN t1.CapacityVolume = 450000 then 9
	WHEN t1.CapacityVolume = 500000 then 10
	WHEN t1.CapacityVolume = 600000 then 12	
	ELSE 0 END) AS Capacity_by_pieces
	, t2.item_number
	, t2.Racking_Qty
	, t2.Pallet_Type
	, t2.ITCLS
	, t2.B2Z95S
	, t2.TIHIUNLD
	, t2.PICKPUT
	, t2.PUTAWAY_CLASS
	, t2.UNITSWIDE
	, t2.UNITLAYERS
	, t2.UNITSDEEP
	, t2.SCOOPQTY
	, t2.SKIDSIZE
	, t2.product_fit_Category
	, t2.Pallet_Qty
	, t2.Racking_Product_CBM
	, CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) AS Loc_UtilizationRate
	, (CASE
			WHEN t2.Racking_Qty IS NULL THEN 'Empty location'
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.05 THEN '0 ~ 5% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.10 THEN '5 ~ 10% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.15 THEN '10 ~ 15% '			
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.20 THEN '15 ~ 20% '
 		    WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.25 THEN '20 ~ 25% '
 		    WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.30 THEN '25 ~ 30% '
 		    WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.35 THEN '30 ~ 35% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.40 THEN '35 ~ 40% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.45 THEN '40 ~ 45% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.50 THEN '45 ~ 50% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.55 THEN '50 ~ 55% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.60 THEN '55 ~ 60% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.65 THEN '60 ~ 65% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.70 THEN '65 ~ 70% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.75 THEN '70 ~ 75% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.80 THEN '75 ~ 80% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.85 THEN '80 ~ 85% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 0.90 THEN '85 ~ 90% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 1 THEN '90 ~ 100% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 1.1 THEN '100 ~ 110% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 1.2 THEN '110 ~ 120% '
			WHEN CONVERT(DECIMAL(10,2),(t2.Racking_Product_CBM/CONVERT(DECIMAL(10,2), (length*0.0254)*(t.width *0.0254)*(t.height *0.0254)))) < 1.3 THEN '120 ~ 130% '
			ELSE 'Over 130%' END) AS 'Range of Loc_Utilization_Rate'

FROM
(
SELECT * FROM Distribution_Warehouse_Wholesale.t_location AS t0
WHERE t0.wh_id IN ('335') AND t0.location_id like 'A3%' AND t0.TypeDescription IN ('I','P','M','A','X')
AND SUBSTRING(t0.location_id,4,2) IN ('10','11','12','13','14','15','16','17','18') 
--AND t0.location_tier NOT IN ('1') 
)  as t  
LEFT JOIN 
(SELECT c.LocationId, MIN(c.CapacityVolume) AS CapacityVolume 
FROM Distribution_Warehouse_Wholesale.t_class_loca c 
--WHERE c.WhId IN ('335') AND c.CapacityVolume>0 and c.LocationId like 'A3%' 
WHERE c.WhId IN ('335') AND c.LocationId like 'A3%' 
GROUP BY c.LocationId 
) as t1 ON t.location_id = t1.LocationId 

---------------- ADD item and qty ---------------------------------------
LEFT JOIN 
(
SELECT r0.item_number
	, r0.location_id
	, r0.Racking_Qty,   
(CASE
	WHEN SUBSTRING(r0.location_id,4,2) IN ('10') AND SUBSTRING(r0.location_id,8,1) IN ('1') AND SUBSTRING(r0.location_id,6,1) IN ('D','F','H','K','M') THEN 'CG_bulk_stack_area'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('10') AND SUBSTRING(r0.location_id,8,1) IN ('1') AND SUBSTRING(r0.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN 'CG_bulk_stack_area'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('11') AND SUBSTRING(r0.location_id,8,1) IN ('1') AND SUBSTRING(r0.location_id,6,2) IN ('FN','FP','FQ','FR','FS','FT','FU','FV','FW','FX','FY','FZ',
	'HA','HB','HC','HD','HE','HF','HG','HH','HJ','HK','HL','HM','HN','HP','HQ','HR','HS','HT','HU','HV','HW','HX','HY','HZ','KA','KB','KC','KD') THEN 'CG_bulk_stack_area'
    WHEN SUBSTRING(r0.location_id,4,2) IN ('15') AND SUBSTRING(r0.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'CG_rails_area'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('17') AND SUBSTRING(r0.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'CG_3.5X7_area'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('17') AND SUBSTRING(r0.location_id,6,1) IN ('D','F','H','K','M','P','R','T','V','X') THEN 'CG_3.5X5_area'
    WHEN SUBSTRING(r0.location_id,4,2) IN ('18') THEN 'CG_bulk_stack_area'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('19','20','21','22','23','24','25')  THEN 'UPH_racking_area'
	ELSE 'CG_racking_area' END) AS location_Category,
(CASE 
	WHEN SUBSTRING(r0.location_id,6,1) IN ('C','E','G','J','L','N','Q','S','U','W') THEN 'A' 
	WHEN SUBSTRING(r0.location_id,6,1) IN ('D','F','H','K','M','P','R','T','V','X') THEN 'B' 
	ELSE 'Check' END
	) AS Location_side,
(CASE
	WHEN SUBSTRING(r0.location_id,4,2) IN ('10') AND SUBSTRING(r0.location_id,8,1) IN ('1') AND SUBSTRING(r0.location_id,6,1) IN ('D','F','H','K','M') THEN 'NO_SKID'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('10') AND SUBSTRING(r0.location_id,8,1) IN ('1') AND SUBSTRING(r0.location_id,6,2) IN ('EN','EP','EQ','ER','ES','ET','EU','EV','EW','EX','EY','EZ',
	'GA','GB','GC','GD','GE','GF','GG','GH','GJ','GK','GL','GM','GN','GP','GQ','GR','GS','GT','GU','GV','GW','GX','GY','GZ','JA','JB','JC','JD') THEN 'NO_SKID'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('10') THEN '5X8'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('11') AND SUBSTRING(r0.location_id,8,1) IN ('1') AND SUBSTRING(r0.location_id,6,2) IN ('FN','FP','FQ','FR','FS','FT','FU','FV','FW','FX','FY','FZ',
	'HA','HB','HC','HD','HE','HF','HG','HH','HJ','HK','HL','HM','HN','HP','HQ','HR','HS','HT','HU','HV','HW','HX','HY','HZ','KA','KB','KC','KD') THEN 'NO_SKID'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('11') THEN '5X7'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('12') THEN '5X5'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('13') THEN '5X7'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('14') THEN '5X5'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('15') THEN '5X7'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('16') THEN '5X5'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('17') AND SUBSTRING(r0.location_id,6,1) IN ('D','F','H','K','M','P','R') THEN '3.5X5'
	WHEN SUBSTRING(r0.location_id,4,2) IN ('17') AND SUBSTRING(r0.location_id,6,1) IN ('C','E','G','J','L','N','Q') THEN '3.5X7'
	ELSE 'NO_SKID' END		
	) AS Pallet_Type
		, i0.ITCLS
		, i0.B2Z95S
		, i0.TIHIUNLD
		, i0.PICKPUT
		, i0.PUTAWAY_CLASS
		, i0.UNITSWIDE
		, i0.UNITLAYERS
		, i0.UNITSDEEP
		, i0.SCOOPQTY
		, i0.SKIDSIZE
		,
	(CASE 
		WHEN i0.ITCLS NOT LIKE 'Z%' THEN 'RP_racking_area'
		WHEN i0.PICKPUT = 'UPH' THEN 'UPH_racking_area'
		WHEN i0.PICKPUT = 'PALLT' AND i0.SKIDSIZE IN ('4') THEN 'CG_3.5X5_area'
		WHEN i0.PICKPUT = 'PALLT' AND i0.SKIDSIZE IN ('5') THEN 'CG_3.5X7_area'	
		WHEN i0.PICKPUT = 'PALLT' AND i0.PUTAWAY_CLASS IN ('RAILS') THEN 'CG_rails_area'
		WHEN i0.PICKPUT = 'PALLT' AND i0.PUTAWAY_CLASS IN ('FLOOR','FLOOROP') THEN 'CG_bulk_stack_area'	
		ELSE 'CG_racking_area' END) AS product_fit_Category,			
		CONVERT(DECIMAL(10,2),r0.Racking_Qty*i0.B2Z95S*0.028317) AS Racking_Product_CBM,
	(CASE 
		WHEN  i0.ITCLS NOT LIKE 'Z%' THEN 0.001
		WHEN  i0.PICKPUT = 'UPH' then 0
		WHEN  i0.PICKPUT = 'PALLT' AND i0.SCOOPQTY=0 THEN CEILING(r0.Racking_Qty/10)
	    ELSE CEILING(r0.Racking_Qty/i0.SCOOPQTY) END) AS Pallet_Qty  
		--ELSE CEILING(r0.Racking_Qty/i0.SCOOPQTY) END) AS Pallet_Qty  
FROM
(
SELECT t1.item_number, t1.location_id, COUNT(t1.serial_number) as Racking_Qty
FROM Distribution_Warehouse_Wholesale.t_serial_active  AS T1
WHERE  t1.wh_id  IN ('335') AND T1.location_id LIKE 'A3%' AND t1.serial_no_status NOT IN ('O') and t1.master_status NOT IN ('S') 
AND SUBSTRING(t1.location_id,4,2) IN ('10','11','12','13','14','15','16','17','18') 
--AND SUBSTRING(t1.location_id,7,1) NOT IN ('1') 
GROUP BY t1.item_number, t1.location_id
) AS r0

LEFT JOIN 
(
SELECT i.ITNBR, i.ITCLS, i.B2Z95S, i1.TIHIUNLD, i1.PICKPUT, i1.PUTAWAY_CLASS, i1.UNITSWIDE, i1.UNITLAYERS, i1.UNITSDEEP, i1.SCOOPQTY, i1.SKIDSIZE 
FROM (SELECT * FROM MasterData_ItemMaster_AFI.ITMRVA AS a WHERE a.STID IN ('335'))  AS i, 
(SELECT b.ITNBR, b.TIHIUNLD, b.PICKPUT, b.ITMCLSID AS PUTAWAY_CLASS, b.UNITSWIDE, b.UNITLAYERS, b.UNITSDEEP, b.SCOOPQTY, b.SKIDSIZE  
FROM MasterData_ItemMaster_AFI.ITBEXT as b WHERE b.House in ('335')
) AS i1 
WHERE i.ITNBR = i1.ITNBR 
) as i0 ON r0.item_number = i0.ITNBR
) AS t2  ON t.location_id = t2.location_id
ORDER BY t.location_id
GO
WITH oh1 as 
(SELECT a1.ITNBR,t2.ITDSC,t2.ITCLS,a1.HOUSE,SUM(a1.LQNTY) AS ONHAND 
FROM Manufacturing_ProductionPlanning_MIL.SLQNTY AS a1 
LEFT JOIN (SELECT a.ITNBR, a.ITCLS, a.ITDSC FROM MasterData_ItemMaster_MIL.ITMRVA AS a WHERE a.STID IN ('51')) AS t2 on a1.itnbr = t2.itnbr 
WHERE a1.HOUSE IN ('51') AND a1.LLOCN NOT IN ('RS001','S01ST1','PIC01','LMF001') 
GROUP BY a1.ITNBR,t2.ITDSC,t2.ITCLS,a1.HOUSE 
) 

-- final table for "Weighted_Avg_Inventory_Age(Days)"
SELECT g.HOUSE, g.ITNBR, g.ONHAND, CAST((SUM(g.Item_Inventory_Age_Days*g.ALC_QTY)/g.ONHAND) AS DECIMAL(10,2)) AS "Weighted_Avg_Inventory_Age(Days)"  
FROM 
(
SELECT t0.HOUSE, t0.ITNBR, t0.UPDDT, t0.TRX_QTY, t0.ACC_QTY, t0.ONHAND, t0.ONHAND-t0.ACC_QTY AS Balance,
-- get item inventory age by item and inbound date
(CASE 
        WHEN t0.ONHAND >= t0.ACC_QTY 
            AND CAST(GETDATE() AS DATE) = CAST(CONCAT('20', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 2, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 4, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 6, 2)) AS DATE) 
            THEN 1 
        WHEN t0.ONHAND >= t0.ACC_QTY 
            AND CAST(GETDATE() AS DATE) > CAST(CONCAT('20', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 2, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 4, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 6, 2)) AS DATE) 
            THEN DATEDIFF(DAY, CAST(CONCAT('20', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 2, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 4, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 6, 2)) AS DATE), CAST(GETDATE() AS DATE)) 
        WHEN t0.ONHAND < t0.ACC_QTY 
            AND ABS(t0.ONHAND - t0.ACC_QTY) < t0.TRX_QTY 
            AND CAST(GETDATE() AS DATE) = CAST(CONCAT('20', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 2, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 4, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 6, 2)) AS DATE) 
            THEN 1 
        WHEN t0.ONHAND < t0.ACC_QTY 
            AND ABS(t0.ONHAND - t0.ACC_QTY) < t0.TRX_QTY 
            AND CAST(GETDATE() AS DATE) > CAST(CONCAT('20', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 2, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 4, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 6, 2)) AS DATE) 
            THEN DATEDIFF(DAY, CAST(CONCAT('20', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 2, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 4, 2), '-', SUBSTRING(CAST(t0.UPDDT AS VARCHAR(8)), 6, 2)) AS DATE), CAST(GETDATE() AS DATE)) 
        WHEN t0.ONHAND < t0.ACC_QTY 
            AND ABS(t0.ONHAND - t0.ACC_QTY) >= t0.TRX_QTY 
            THEN 0 
        ELSE 0 
    END) AS Item_Inventory_Age_Days,

-- get allocated qty
(CASE 
    WHEN t0.ONHAND > t0.ACC_QTY THEN t0.TRX_QTY
    WHEN t0.ONHAND-t0.ACC_QTY<0 AND ABS(t0.ONHAND-t0.ACC_QTY) < t0.TRX_QTY THEN T0.TRX_QTY - ABS(t0.ONHAND-t0.ACC_QTY)
    WHEN t0.ONHAND-t0.ACC_QTY<0 AND ABS(t0.ONHAND-t0.ACC_QTY) >= t0.TRX_QTY THEN 0 ELSE 0 END ) AS ALC_QTY

FROM
-- get inbound acccumulated qty
(
SELECT a.HOUSE, a.ITNBR, a.UPDDT, a.TRX_QTY, SUM(a.TRX_QTY) OVER (PARTITION BY a.ITNBR ORDER BY a.UPDDT DESC) AS ACC_QTY, oh1.ONHAND 
FROM 
(SELECT T1.HOUSE, T1.ITNBR, T1.UPDDT, SUM(T1.TRQTY) as TRX_QTY 
FROM Manufacturing_Inventory_MIL.IMHIST AS T1
WHERE T1.HOUSE='51' AND EXISTS ( SELECT 1 FROM (SELECT i.ITNBR FROM Manufacturing_ProductionPlanning_MIL.SLQNTY  AS i WHERE i.LQNTY <> 0 AND i.HOUSE IN ('51') AND i.LLOCN NOT IN ('RS001','S01ST1','PIC01','LMF001') GROUP BY i.ITNBR) AS b1 WHERE b1.ITNBR = T1.ITNBR)      
AND T1.UPDDT BETWEEN '1'+ SUBSTRING(CONVERT(VARCHAR(8), GETDATE() - 720, 112),3,6) AND '1'+SUBSTRING(CONVERT(VARCHAR(8), GETDATE(), 112),3,6)   
AND T1.TRQTY<>0 AND T1.TCODE IN ('RP','RI','RM','RS') 
GROUP BY T1.ITNBR, T1.HOUSE, T1.UPDDT
) AS a, oh1 WHERE a.ITNBR = oh1.ITNBR) AS t0 
WHERE (CASE 
    WHEN t0.ONHAND > t0.ACC_QTY THEN t0.TRX_QTY
    WHEN t0.ONHAND-t0.ACC_QTY<0 AND ABS(t0.ONHAND-t0.ACC_QTY) < t0.TRX_QTY THEN T0.TRX_QTY-ABS(t0.ONHAND-t0.ACC_QTY)
    WHEN t0.ONHAND-t0.ACC_QTY<0 AND ABS(t0.ONHAND-t0.ACC_QTY) >= t0.TRX_QTY THEN 0 ELSE 0 END ) >0
--ORDER BY t0.ITNBR, t0.UPDDT DESC
) AS g 
GROUP BY g.HOUSE, g.ITNBR, g.ONHAND
GO
-- First, we need to calculate the total quantity of each item for each week
WITH weekly_quantity AS (
    SELECT 
        ITNBR, 
       -- item_category, 
        DATEPART(wk, transaction_date) AS week_number, 
        SUM(CASE WHEN transaction_type = 'in' THEN quantity ELSE -quantity END) AS total_quantity
    FROM 
        Manufacturing_Inventory_MIL.IMHIST AS t1
    GROUP BY 
        ITNBR, 
        item_category, 
        DATEPART(wk, transaction_date)
),

-- Then, we calculate the average inventory for each item for each week
average_inventory AS (
    SELECT 
        ITNBR, 
        item_category, 
        week_number, 
        AVG(total_quantity) OVER (PARTITION BY ITNBR, item_category ORDER BY week_number ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS avg_inventory
    FROM 
        weekly_quantity
)

-- Finally, we calculate the inventory turns by dividing the total quantity by the average inventory
SELECT 
    ITNBR, 
    item_category, 
    week_number, 
    total_quantity / NULLIF(avg_inventory, 0) AS inventory_turns
FROM 
    weekly_quantity 
JOIN 
    average_inventory USING (ITNBR, item_category, week_number);

