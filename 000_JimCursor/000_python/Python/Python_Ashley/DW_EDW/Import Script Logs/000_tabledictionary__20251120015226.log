SELECT 
	   a.[Date]
	  ,a.[wh_id]
      ,a.[item_number]
	  ,a.[employee_id]
      ,a.[suggested_value]
      ,a.[entered_value]
	  ,a.Unit_Type
      --,sum(a.[quantity]) as putaway_overridden_quantity
	  --,a.[EMPLOYEENUMBER]
   --   ,a.[EMPLOYEEREPORTNAME]
   --   ,a.[SupervisorName]
	  ,count(*) as putaway_override_count
FROM(
SELECT a.[tran_type]
      ,a.[description]
      ,a.[exception_date]
      ,a.[exception_time]
	  ,CAST(a.[exception_date] AS DATE) [Date]
      ,a.[employee_id]
      ,b.[EMPLOYEENUMBER]
      ,b.[EMPLOYEEREPORTNAME]
      ,b.[SupervisorName]
      ,a.[wh_id]
      ,a.[suggested_value]
      ,a.[entered_value]
      ,a.[location_id]
      ,a.[item_number]
      ,a.[lot_number]
      ,a.[quantity]
      ,a.[hu_id]
      ,a.[load_id]
      ,a.[control_number]
      ,a.[line_number]
	  ,CASE WHEN c.pick_put_id NOT LIKE '%UPH%' THEN 'Casegoods' ELSE 'UPH' END  [Unit_Type]


  FROM [Distribution_Warehouse_Wholesale].[ExceptionLog] a
  LEFT JOIN [PowerBI_Distribution].[WhsEmployee] b
  on a.[employee_id] = right('000000'+ cast(trim(cast(b.EMPLOYEENUMBER as VARCHAR(10))) as VARCHAR(6)), 6)
  AND a.wh_id=b.[Warehouse]
  LEFT JOIN Distribution_Warehouse_wholesale.t_item_master c
  ON a.item_number=c.item_number
  AND a.wh_id=c.wh_id

  WHERE CAST(a.exception_date AS DATE) BETWEEN DATEADD(Month,-3,GETDATE()) AND GETDATE()
  --where exception_date between '20220116' AND '20220116'
  AND a.tran_type in ( '99D', '101', '115' )
  AND c.commodity_code LIKE 'Z%'
  AND c.commodity_code NOT LIKE '%K'
  AND a.wh_id in ('335')

  --AND a.wh_id in ('1')

  ) a


	group by

	--   a.[Date]
	--  ,a.[wh_id]
 --     ,a.[item_number]
	--  ,a.[employee_id]
 --     ,a.[suggested_value]
 --     ,a.[entered_value]
	--  ,a.Unit_Type
	--  ,a.[EMPLOYEENUMBER]
 --     ,a.[EMPLOYEEREPORTNAME]
 --     ,a.[SupervisorName]

 	   a.[Date]
	  ,a.[wh_id]
      ,a.[item_number]
	  ,a.[employee_id]
      ,a.[suggested_value]
      ,a.[entered_value]
	  ,a.Unit_Type

	  order by
	    a.[wh_id],
		a.[Date],
		a.[item_number]

