-- Ashton receiving stage and shipping stage

WITH itm AS (
    SELECT a.STID, a.ITNBR, a.ITCLS, a.B2Z95S
    FROM MasterData_ItemMaster_AFI.ITMRVA AS a
    WHERE a.STID = '335'),
sn AS (
    SELECT a1.wh_id,
           a1.serial_number,
           a1.item_number,
           a1.po_number,
           a1.serial_no_status,
           a1.master_status,
           a1.master_po,
           a1.trip_number,
           a1.location_id,
           a1.hu_id,
           a1.received_date
    FROM Distribution_Warehouse_Wholesale.t_serial_active  AS a1
    WHERE  a1.wh_id  IN ('335')
      AND a1.serial_no_status NOT IN ('O') AND a1.master_status NOT IN ('S')
    )
SELECT sn.*,
    CAST(sn.received_date AS DATE) AS receiving_date_2,
    itm.ITCLS as item_class,
    CASE
        WHEN sn.location_id LIKE 'RS%' THEN 'Receiving_Stage_loc'
        WHEN sn.trip_number IS NOT null AND sn.location_id LIKE 'D%' Then 'Shipping_Door_Loc'
        WHEN sn.trip_number IS NOT null AND sn.location_id LIKE 'S%' Then 'Shipping_Stage_loc'
        ELSE 'Racking_Location' END AS Location_Type,
    CASE
		WHEN itm.ITCLS NOT LIKE 'Z%' THEN 'RP'
        WHEN sn.item_number = 'RP ORDER' THEN 'RP'
		WHEN SUBSTRING(TRIM(sn.item_number),1,4) IN ('100-') THEN 'CG'
		WHEN SUBSTRING(TRIM(sn.item_number),1,1) IN ('1','2','3','4','5','6','7','8','9','U') THEN 'UPH'
		WHEN SUBSTRING(TRIM(sn.item_number),1,1) IN ('A') AND itm.B2Z95S*0.028317<=0.4 THEN 'ACCESSORY'
		WHEN SUBSTRING(TRIM(sn.item_number),1,1) IN ('L','Q','R') THEN 'ACCESSORY'
		WHEN SUBSTRING(TRIM(sn.item_number),1,1) IN ('M') AND LEN(sn.item_number) = 6 THEN 'ACCESSORY'
		ELSE 'CG' END AS Product
FROM sn as sn
LEFT JOIN itm as itm ON itm.ITNBR = sn.item_number AND itm.STID = sn.wh_id
WHERE   CASE
        WHEN sn.location_id LIKE 'RS%' THEN 'Receiving_Stage_loc'
        WHEN sn.trip_number IS NOT null AND sn.location_id LIKE 'D%' Then 'Shipping_Door_Loc'
        WHEN sn.trip_number IS NOT null AND sn.location_id LIKE 'S%' Then 'Shipping_Stage_loc'
        ELSE 'Racking_Location' END NOT IN ('Racking_Location')
