With u AS
-- US DC shortage BI
(
SELECT 
	   [equipment_id] AS [Equipment ID]
      ,[Inventory Type]
      ,[item_number] AS [Item #]
      ,[pomvendornum] AS [Vendor#]
      ,[Vendor NAME] AS [Vendor Name]
      ,[Vendor Import Domestic Flag]
      ,[Vendor Country]
      ,[Shipped Pcs]
      ,[Received Pcs Without Damage]
      ,[Damaged Pcs]
      ,[Shortage Pcs]
      ,[Overage Pcs]
      ,[Total Received Pcs]
      ,[PO]
      ,[On Shipped ASN Record]
	  ,[Percent_Complete]
      ,[Percent_Complete] / 100 AS [% Complete]
	  --,[Damaged Pcs] / [Shipped Pcs] AS [% Damage]
	  --,[Overage Pcs] / [Shipped Pcs] AS [% Overage] -- Change to Total Received
	  --,[Shortage Pcs] / [Shipped Pcs] AS [% Shortage]
      ,[Expected_arrival] AS [Expected Arrival]
      ,[asn_number] AS [ASN #]
      ,[Warehouse ID] AS [Destination DC]
      ,[Entered_yard] AS [Entered Yard]
      ,[Exited_yard] AS [Exited Yard]
      ,[Load Type]
      ,[Actual Ship Date]
      ,[Origin DC]
  FROM [PowerBI_Distribution].[VendorShipmentDetails] as b
  WHERE (b.[Vendor NAME] LIKE 'WANEK%' OR b.[Vendor NAME] LIKE 'MIL%') AND (b.[Shortage Pcs]>0 )   
  -- OR b.[Overage Pcs]>0
		AND CAST(b.[Entered_yard] AS DATE) > '2024-01-01'),
m AS
-- base on BI.container# to get MIL serial number details of trx 361
(
SELECT t1.wh_id
	, CAST(t1.[start_tran_date] AS DATE) AS Transaction_Date
	, t1.item_number
	, t1.description
	, t2.ITCLS as Item_Class
	, (CASE 
        WHEN t2.ITCLS like 'TAF%' THEN 'RP'
        WHEN t2.ITCLS IN ('MTA','CTA','FFR','MVN') THEN 'RP'
        WHEN t2.ITCLS IN ('PACS','ZACM','WVVG') THEN 'UnKits'
        WHEN t2.ITCLS LIKE 'Z%K'  THEN 'UnKits'
        WHEN t2.ITCLS IN ('ZDTP','ZKBP')  THEN 'Pillow'
        WHEN t2.ITCLS IN ('ZASU','ZMLH','ZMLR','ZUSR','ZUSU','ZVUC','ZXUC','ZUSU','ZUMU','ZAMU','ZASM','ZASR','ZDMA','ZMUC','ZSUS','ZUMS','ZUSM','ZVMA','ZVUS','ZXLH','ZXLM','ZXLR','ZXMS','ZXMU') THEN 'UPH'
        WHEN t2.ITCLS IN ('ZDAA','ZDAE','ZDWC','ZDAY','ZVAA','ZDAB','ZDAW','ZDYB','ZDBC','ZABC','ZECD') THEN 'CG'
        WHEN t2.ITCLS IN ('ZKIS','ZAIS','ZKBA','ZNFR','ZKBP','ZNFR') THEN 'Bedding'		
        WHEN t2.ITCLS IN ('WPLS') THEN 'Plastics'
        WHEN t2.ITCLS IN ('WVBC','WVCS') THEN 'Foundation'		
		WHEN t2.ITCLS IN ('PANL') THEN 'Panel'
		WHEN t2.ITCLS IN ('ZKIZ') THEN 'ZipperCover'
        WHEN t2.ITCLS IN ('BBFR','WVHC') THEN 'Verona'		
		WHEN t2.ITCLS NOT LIKE 'Z%' THEN 'RawMaterial' 
        ELSE 'Check' END) AS Product
	, CAST(t1.lot_number AS VARCHAR(20)) AS SN
    , t1.tran_qty
	, t1.routing_code as container_nbr
FROM Distribution_Warehouse_Wholesale.TranLog AS t1
LEFT JOIN (SELECT a.ITNBR, a.ITCLS FROM MasterData_ItemMaster_AFI.ITMRVA AS a WHERE a.STID = '51') AS t2 ON t1.item_number = t2.ITNBR
WHERE t1.wh_id IN ('51') AND t1.start_tran_date > '2024-01-01'  AND t1.tran_type IN ('361') 
AND t1.routing_code in (SELECT u.[Equipment ID] FROM u)
--ORDER BY t1.item_number
)

